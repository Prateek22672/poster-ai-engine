# ── AI Provider ────────────────────────────────────────────────────
AI_PROVIDER=openai

# ── OpenAI — ALL features run on this one key ──────────────────────
# Embeddings: text-embedding-3-small (RAG)
# LLM: gpt-4o (intent extraction + layout planning)
# Vision: gpt-4o (reference image analysis)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Supabase ────────────────────────────────────────────────────────
# https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Cloudinary ──────────────────────────────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Pexels (free stock photos for poster backgrounds) ──────────────
# https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-key

# ── Security guards (defense-in-depth for our own endpoint) ────────
# Max generate requests per IP per minute (0 disables)
RATE_LIMIT_PER_MIN=12
# Hard daily spend kill-switch in USD (0 disables). Blocks /api/generate once
# today's logged OpenAI spend reaches this. Protects against runaway/abuse.
DAILY_BUDGET_USD=5
# Max prompt length
MAX_PROMPT_LEN=2000

# ── Realtor integration (shared secrets — identical on the PHP side) ──
POSTER_ENGINE_API_KEY=pe_...
POSTER_ENGINE_HMAC_SECRET=...64hex...
ENGINE_VERSION=1.0.0

# ── Admin panel (gates /admin) ─────────────────────────────────────
ADMIN_PASSWORD=set-a-strong-password

# ── Seed secret ─────────────────────────────────────────────────────
# Any random string — used to protect POST /api/seed
# curl -X POST http://localhost:3000/api/seed \
#   -H "Authorization: Bearer <your value here>"
SEED_SECRET=change-me-to-something-random
